# Set default behavior to automatically normalize line endings
* text=auto

# Denote all files that are truly to be treated as text and want LF normalization on checkin
*.js text
*.jsx text
*.ts text
*.tsx text
*.css text
*.html text
*.json text
*.md text

# Denote all files that are truly to be treated as binary and should not be modified
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.gz binary
*.tar binary
